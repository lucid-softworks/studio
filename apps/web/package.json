{
  "name": "@studio/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "build:e2e": "tsc -b && vite build --mode e2e",
    "preview:cloudflare": "wrangler dev --config ../../wrangler.jsonc",
    "deploy:cloudflare": "wrangler deploy --config ../../wrangler.jsonc",
    "lint": "oxlint src vite.config.ts",
    "test": "vitest run src --passWithNoTests",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@studio/editor": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.2",
    "unplugin-typegpu": "0.11.6",
    "vite": "^8.1.4"
  }
}
