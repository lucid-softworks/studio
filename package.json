{
  "name": "@studio/root",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "turbo run dev --filter=@studio/web",
    "dev:desktop": "turbo run dev --filter=@studio/web --filter=@studio/desktop",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "oxlint": "^1.71.0",
    "turbo": "^2.10.5",
    "typescript": "~6.0.2",
    "vitest": "^4.1.10"
  }
}
