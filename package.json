{
  "name": "@studio/root",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "turbo run dev --filter=@studio/web",
    "dev:desktop": "turbo run dev --filter=@studio/web --filter=@studio/desktop",
    "preview:cloudflare": "pnpm --filter @studio/web build && pnpm --filter @studio/web preview:cloudflare",
    "deploy:cloudflare": "pnpm --filter @studio/web build && pnpm --filter @studio/web deploy:cloudflare",
    "build": "turbo run build",
    "test:e2e": "playwright test",
    "lint": "oxlint --report-unused-disable-directives .",
    "lint:fix": "oxlint --fix .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.24.0",
    "turbo": "^2.10.5",
    "typescript": "~6.0.2",
    "vitest": "^4.1.10"
  }
}
